def upload_to_hf(local_dir, repo_name, private=True):
    repo_id = f"{HF_USERNAME}/{repo_name}"
    create_repo(repo_id, repo_type="model", private=private, exist_ok=True)
    print(f"Uploading {local_dir} → {repo_id} ...")
    api.upload_folder(
        folder_path=local_dir,
        repo_id=repo_id,
        commit_message=f"Upload {repo_name}",
    )
    print(f"✓ https://huggingface.co/{repo_id}\n")
    return repo_id
	
